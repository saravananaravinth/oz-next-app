{
  "name": "oz-next-app",
  "version": "0.1.0",
  "description": "Enterprise Ozotec ERP frontend on Next.js, TypeScript, shadcn/ui, and OpenNext Cloudflare.",
  "private": true,
  "type": "module",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=24.0.0 <25.0.0",
    "npm": ">=11.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc -p tsconfig.json --noEmit --pretty false",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "node --test --test-reporter=spec",
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "security:audit": "npm audit --omit=dev --audit-level=high",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm run test",
    "verify": "npm run check && npm run build && npm run audit:prod",
    "ci": "npm run verify",
    "build:cf": "opennextjs-cloudflare build",
    "preview": "npm run build:cf && opennextjs-cloudflare preview",
    "upload": "npm run build:cf && opennextjs-cloudflare upload",
    "deploy": "npm run verify && npm run build:cf && opennextjs-cloudflare deploy",
    "cf:typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts",
    "cf-typegen": "npm run cf:typegen"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@hookform/resolvers": "^5.4.0",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.12",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.20.0",
    "next": "16.2.9",
    "next-themes": "^0.4.6",
    "nuqs": "^2.8.5",
    "radix-ui": "^1.6.0",
    "react": "19.2.7",
    "react-day-picker": "^10.0.1",
    "react-dom": "19.2.7",
    "react-error-boundary": "^6.1.2",
    "react-hook-form": "^7.79.0",
    "react-resizable-panels": "^4.11.2",
    "recharts": "^3.8.1",
    "server-only": "0.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@eslint/eslintrc": "^3.3.1",
    "@opennextjs/cloudflare": "^1.19.11",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^24.10.1",
    "@types/react": "^19.1.7",
    "@types/react-dom": "^19.1.7",
    "eslint": "^9.39.1",
    "eslint-config-next": "16.2.9",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.5.0",
    "prettier": "^3.6.2",
    "shadcn": "^4.11.0",
    "tailwindcss": "^4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0",
    "wrangler": "^4.100.0"
  },
  "overrides": {
    "esbuild": "0.28.1",
    "postcss": "8.5.10",
    "ws": "8.21.0"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "sharp@0.34.5": true,
    "unrs-resolver@1.12.2": true,
    "workerd@1.20260702.1": true
  }
}
