# ==============================================================================

# Dependencies
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Build outputs / generated artifacts
.next/
.open-next/
.vercel/
.wrangler/
.wrangler-state/
.mf/
.turbo/
dist/
build/
out/
coverage/
test-results/
playwright-report/
bundles/

# TypeScript / framework generated types
*.tsbuildinfo
tsconfig.tsbuildinfo
.next/cache/tsconfig.tsbuildinfo
next-env.d.ts
cloudflare-env.d.ts
worker-configuration.d.ts

# Local environment files
.env
.env.*
!.env.example
!.env.sample
!.env.template
.dev.vars
.dev.vars.*
!.dev.vars.example

# Secrets / credentials / private material
.secrets/
secrets/
private/
*.pem
*.key
*.crt
*.csr
*.p12
*.pfx
*.jks
*.keystore
*service-account*.json
*service_account*.json
*gcp*.json
*google*.json
*credential*.json
*credentials*.json
application_default_credentials.json

# Logs / reports / runtime noise
logs/
*.log
*.pid
*.seed
*.pid.lock
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
wrangler-debug.log
.eslintcache
.prettier-cache

# OS / editor noise
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
!.vscode/tasks.json
*.swp
*.swo
*~

# Local archives / handoff files
*.zip
*.tar
*.tar.gz
*.tgz
*.rar

# Keep deterministic npm installs tracked
!package-lock.json